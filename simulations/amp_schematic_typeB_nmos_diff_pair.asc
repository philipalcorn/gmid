TEXT 928 432 Left 2 !;hdifval param -- hdifval MUST EQUAL 0.25u -- DO NOT CHANGE THIS VALUE\n.param hdifval=0.25u\n \n;diff pair params\n.param W1_op=8.00u L1_op=0.30u M1_op=1\n;.param W1_op=3.00u L1_op=0.30u M1_op=10\n \n;M3 through M10 device multiplier params\n;.param M3_op=100 M45_op=120 Mx_op=70\n.param M3_op=30 M45_op=31 Mx_op=16\n \n;output device params, M1out, M5outR, M2out, M7outR\n.param Wnout_op=1.85u Lnout_op=0.30u Mnout_op=37 MnoutR_op=1\n.param Wpout_op=10.00u Lpout_op=0.30u Mpout_op=37 MpoutR_op=1\n \n;floating current mirror (FCM) params, M3fcm, M6fcmR, M4fcm, M8fcmR\n.param Wnfcm_op=0.63u Lnfcm_op=0.30u Mnfcm_op={Mx_op}/2 MnfcmR_op=1\n.param Wpfcm_op=3.04u Lpfcm_op=0.30u Mpfcm_op={Mx_op}/2 MpfcmR_op=1\n.param Mb1_op=1 Mb2_op=1\n \n;output compensation network params for C1c, R1c, M1c, C2c, R2c, M2c\n.param C1c_op=700f\n.param R1c_op=1200\n.param Wnc_op=1.10u Lnc_op=0.30u Mnc_op=1\n.param C2c_op=1000f\n.param R2c_op=3000\n.param Wpc_op=0.90u Lpc_op=0.30u Mpc_op=1\n \n;pmos current mirror params\n.param Wp_op=8.08u Lp_op=0.30u Lcasp_op=0.30u Lpx_op=0.98u\n \n;nmos current mirror params\n.param Wn_op=1.57u Ln_op=0.30u Lcasn_op=0.30u Lnx_op=0.64u
TEXT 3320 -1808 Left 2 ;Ip = Iunit*M45_op
TEXT 3320 -320 Left 2 ;Ix = Iunit*Mx_op
TEXT 928 1752 Left 2 ;hdifval should be set to the value HDIF in your model file that you are using for the project;\ndo not change the hdifval parameter value;\n \nwith the exception of hdifval (don't change this value), you will only make changes to the \nparameters above and the SW1 and SW2 switch settings; you are not to make any other \nchanges to this schematic; see the additional guidelines below;\n \n(M3_op/2) + Mx_op MUST EQUAL M45_op;  note that M3_op must be even;\n \nMx_op should be even to help make the FCM replica bias circuit design go more smoothly;\n \nmin/max device length: {0.30um, 10.00um}; min/max device width: {0.30um, 100.00um};\n \nenter all device lengths and widths with engineering prefix u (for micron, i.e., micrometer);\n \nround all lengths and widths to 2 decimal places of precision in units of um (e.g., W=13.167um \nshould be rounded to 13.17um; L=3.831um should be rounded to 3.83um); you cannot use\nwidths or lengths outside of the stated bounds above or with more than two decimal places\nof precision;\n \nexample: suppose you need a device with width W=120um; since Wmax=100.00um, you'll need \nto break the device up into smaller widths in parallel and select an appropriate multiplier; e.g., \nW=30.00um with m=4, or W=40.00um with m=3, and so on;\n \nC1c_op and C2c_op should be in f with zero decimal places of precision; e.g., 723f, 1298f, etc.;\n \ndon't forget: in the fdbk_filter_schematic.asc schematic file, you also need to set the values \nof the Rfb_op and Cfb_op parameters;
